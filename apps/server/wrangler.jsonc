{
  "$schema": "node_modules/wrangler/config-schema.json",
	"name": "zenpost-server",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-17",
	"compatibility_flags": ["nodejs_compat"],
	"keep_vars": true,
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"assets": {
		"directory": "./public"
	}
}
