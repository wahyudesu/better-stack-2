{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@hono/node-server": "^1.14.4",
    "@scalar/hono-api-reference": "^0.10.9",
    "@zenpost/env": "workspace:*",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "wrangler": "^4.84.1",
    "yaml": "^2.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@zenpost/config": "workspace:*",
    "tsdown": "^0.16.5",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
