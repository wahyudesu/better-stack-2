{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "OPENNEXT_DISABLE_MONOREPO=1 opennextjs-cloudflare build",
    "start": "next start",
    "dev:bare": "next dev --port 3001",
