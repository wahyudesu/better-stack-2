    "babel-plugin-react-compiler": "^1.0.0",
    "clsx": "^2.1.1",
    "convex": "^1.34.0",
    "dotenv": "catalog:",
    "lucide-react": "catalog:",
    "next": "^16.2.0",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "^3.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-stack-2/config": "workspace:*",
    "@cloudflare/workers-types": "catalog:",
    "@tailwindcss/postcss": "^4.1.18",
