{
  "name": "zenpost",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "check-types": "pnpm -r check-types",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "dev:landing": "pnpm --filter landing dev",
    "deploy": "pnpm --filter @zenpost/infra deploy",
    "destroy": "pnpm --filter @zenpost/infra destroy"
  },
  "dependencies": {
    "@zenpost/env": "workspace:*",
    "dotenv": "catalog:",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "^22.13.14",
    "@zenpost/config": "workspace:*",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.27.0"
}
